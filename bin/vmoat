#!/usr/bin/env bash
# vmoat -- give the current git worktree its own Colima VM and run the
# project's build/test commands inside it. Project-agnostic; driven by a
# vmoat.conf at the consuming repo root.
#
# Usage: vmoat <command> [args]
set -euo pipefail

# resolve our own location (following symlinks) to find lib/.
_src="${BASH_SOURCE[0]:-$0}"
while [ -h "$_src" ]; do
  _dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
  _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_dir/$_src" ;; esac
done
SELF_DIR=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
LIB_DIR="$SELF_DIR/../lib"

# shellcheck source=lib/common.sh
. "$LIB_DIR/common.sh"
# shellcheck source=lib/commands.sh
. "$LIB_DIR/commands.sh"

usage() {
  cat >&2 <<'EOF'
vmoat -- one ephemeral Colima VM per git worktree.

Commands (operate on the CURRENT git worktree):
  init          Scaffold a vmoat.conf (optional; CMD_UP is auto-detected).
  up            run CMD_UP inside the VM (+ wait for health if set).
  test [args]   Run CMD_TEST [args] inside the VM (localhost = the stack).
  tunnel [port] Forward in-VM port(s) to the host (default: discovered ports).
  untunnel      Close all tunnels for this worktree's VM.
  status        Show VM status, containers, health, and open tunnels.
  provision     Create/start the worktree's VM; install toolchain; seed files.
  ssh [cmd]     Shell into the VM (or run a command in the worktree dir).
  down          Stop the VM (keeps disk).
  destroy [-f]  Delete the VM entirely.
  name          Print the VM/profile name for this worktree.

Config: <repo-root>/vmoat.conf is OPTIONAL (copy vmoat.example.conf to customize).
EOF
}

main() {
  local cmd="${1:-}"; [ "$#" -gt 0 ] && shift || true

  case "$cmd" in
    ""|help|-h|--help) usage; exit 0 ;;
    version|--version) printf 'vmoat %s\n' "$WTVM_VERSION"; exit 0 ;;
  esac

  resolve_repo
  load_config
  VM=$(vm_name)

  case "$cmd" in
    init)      cmd_init ;;
    provision) cmd_provision ;;
    up)        cmd_up ;;
    test)      cmd_test "$@" ;;
    tunnel)    cmd_tunnel "$@" ;;
    untunnel)  cmd_untunnel ;;
    status)    cmd_status ;;
    ssh)       cmd_ssh "$@" ;;
    down)      cmd_down ;;
    destroy)   if [ "${1:-}" = "-f" ]; then WTVM_FORCE=1; fi; cmd_destroy ;;
    name)      printf '%s\n' "$VM" ;;
    *)         die "Unknown command: '$cmd' (try 'vmoat help')." ;;
  esac
}

WTVM_VERSION="0.1.0"
main "$@"
